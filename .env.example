# =============================================================================
# Dooglys AI-bot — шаблон окружения (Telegram-only деплой, N ботов).
# Скопируй в .env рядом с docker-compose.yml и заполни. .env в git НЕ коммитим —
# только этот пример с пустыми секретами.
#
#   cp .env.example .env  &&  <заполнить>  &&  docker compose up -d --build
#
# 🔒 = секрет: живёт ТОЛЬКО в .env на сервере, никогда в git и никогда в образе.
# =============================================================================

# --- Режим приложения ---------------------------------------------------------
# prod → строгие инварианты безопасности: пустой allowlist у тенанта = падение на
#        старте (fail-fast), чтобы бот не оказался открыт всем. dev → послабления.
APP_ENV=prod
# llm → реальная модель через роутер; stub → детерминированные планы без сети/GPU.
PLANNER_MODE=llm

# --- LLM-роутер (боевой) ------------------------------------------------------
# Базовый домен БЕЗ /v1 — клиент сам добавит /v1/chat/completions.
LLM_BASE_URL=https://litellm.site.avtosushi.net
LLM_MODEL=gemma-4-31b
# 🔒 Bearer-токен роутера.
LLM_API_KEY=
# response_format=json_object. Если LiteLLM/vLLM/модель не поддержит — поставь false
# (движок деградирует на parse+repair). Проверить curl'ом с сервера.
LLM_FORCE_JSON=true
# Таймаут одного запроса к модели (формат time.ParseDuration).
LLM_TIMEOUT=180s

# --- Источник данных: Report-API (боевой api.dooglys.com) ---------------------
DGS_CLIENT=api
DGS_REPORT_AUTH=token
DGS_REPORT_BASE=https://api.dooglys.com/api/v1/reports
# 🔒 Общий access-token на всех тенантов. В ЭТОМ проекте у каждого тенанта СВОЙ токен —
#    оставь ПУСТЫМ и задай пер-тенантно (TENANT_<k>_ACCESS_TOKEN в блоках ниже).
DGS_ACCESS_TOKEN=

# --- Логи (JSONL на томе ./data) ----------------------------------------------
# Один процесс на все боты → один файл; tenant/user пишутся в каждой строке.
# Пусто → лог выключен.
QUERY_LOG_PATH=/app/data/queries.jsonl
FEEDBACK_LOG_PATH=/app/data/feedback.jsonl

# --- Владелец каталога логов --------------------------------------------------
# Контейнер запускается под ЭТИМ uid/gid (docker-compose.yml → user:), чтобы писать
# в bind-mount ./data под твоим хостовым пользователем — без chown под чужой uid.
# Узнать свои: id -u  и  id -g. На большинстве однопользовательских VPS — 1000/1000.
HOST_UID=1000
HOST_GID=1000

# =============================================================================
# ТЕНАНТЫ (= боты). Как завести несколько ботов:
#
#   1) Перечисли КЛЮЧИ тенантов через запятую в TENANTS. Ключ — произвольный ярлык
#      (удобно взять = домену тенанта). Каждый ключ = отдельный бот.
#   2) На каждый ключ <k> задай блок переменных TENANT_<k>_*.
#
# tenant_id vs tenant_domain (важно для будущего залива в кубы):
#   TENANT_<k>_ID     — tenant_id: ключ реестра/tenants.example.json. Во ВНЕШНЕМ режиме
#                       (token, демо) не обязателен (не задан → = ключ). Во ВНУТРЕННЕМ режиме
#                       в кубах (xcontext) уходит в x-context вместе с доменом — и там это
#                       ОТДЕЛЬНОЕ значение (часто UUID), не равное домену.
#   TENANT_<k>_DOMAIN — tenant-domain: по нему Report-API узнаёт тенанта во внешнем режиме
#                       (не задан → = ID).
#   TENANT_<k>_ACCESS_TOKEN — СВОЙ у каждого тенанта (обязателен; общий DGS_ACCESS_TOKEN не используем)
#
# ALLOWLIST — смешанный whitelist через запятую: @username И/ИЛИ числовой chat_id.
#   @username — регистр и '@' не важны (@Ivan == ivan); удобно, но username изменяем.
#   chat_id   — числовой, неизменяемый (надёжнее). Узнать id: @userinfobot.
#   В APP_ENV=prod хотя бы один элемент обязателен, иначе fail-fast на старте.
# =============================================================================

# Боты поднимаются РОВНО по списку TENANTS. Сейчас 5 ключей — убери лишний, если ботов 4.
# Комментарии — только на отдельной строке (docker compose env_file может не срезать
# инлайн-'#' после значения → мусор попадёт в переменную).
TENANTS=rukagreka,ipkazakova,ambapizza,daynight,wasabi

# --- бот 1: rukagreka ---------------------------------------------------------
# 🔒 токен @BotFather:
TENANT_rukagreka_BOT_TOKEN=
# tenant_id (для кубов/xcontext; пусто → = ключ "rukagreka"):
TENANT_rukagreka_ID=
# tenant-domain для Report-API (пусто → = ID):
TENANT_rukagreka_DOMAIN=
TENANT_rukagreka_ALLOWLIST=@owner_ivan, 100200300
# 🔒 свой access-token тенанта (у каждого свой):
TENANT_rukagreka_ACCESS_TOKEN=

# --- бот 2: ipkazakova --------------------------------------------------------
TENANT_ipkazakova_BOT_TOKEN=
TENANT_ipkazakova_ID=
TENANT_ipkazakova_DOMAIN=
# ⚠ ниже '@' один = ПУСТОЙ allowlist → в APP_ENV=prod бот НЕ стартует. Впиши @username или chat_id.
TENANT_ipkazakova_ALLOWLIST=@
TENANT_ipkazakova_ACCESS_TOKEN=

# --- бот 3: ambapizza ---------------------------------------------------------
TENANT_ambapizza_BOT_TOKEN=
TENANT_ambapizza_ID=
TENANT_ambapizza_DOMAIN=
# ⚠ то же: заполни allowlist, иначе fail-fast в prod.
TENANT_ambapizza_ALLOWLIST=@
TENANT_ambapizza_ACCESS_TOKEN=

# --- бот 4: daynight ----------------------------------------------------------
TENANT_daynight_BOT_TOKEN=
TENANT_daynight_ID=
TENANT_daynight_DOMAIN=
TENANT_daynight_ALLOWLIST=400500600
TENANT_daynight_ACCESS_TOKEN=

# --- бот 5: wasabi ------------------------------------------------------------
TENANT_wasabi_BOT_TOKEN=
TENANT_wasabi_ID=
TENANT_wasabi_DOMAIN=
TENANT_wasabi_ALLOWLIST=@owner_petr, 700800900
TENANT_wasabi_ACCESS_TOKEN=

# Добавить бота = дописать ключ в TENANTS и блок TENANT_<ключ>_* — код не меняется.
