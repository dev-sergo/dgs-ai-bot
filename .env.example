# =============================================================================
# Dooglys AI-bot — environment template (Telegram-only deploy, N bots).
# Copy to .env next to docker-compose.yml and fill in. .env is NOT committed —
# only this example with empty secrets.
#
#   cp .env.example .env  &&  <fill in>  &&  docker compose up -d --build
#
# 🔒 = secret: lives ONLY in .env on the server, never in git and never in the image.
# =============================================================================

# --- App mode -----------------------------------------------------------------
# prod → strict security invariants: an empty allowlist for a tenant = fail-fast on
#        startup (so a bot is never open to everyone). dev → relaxed.
APP_ENV=prod
# llm → real model via the router; stub → deterministic plans, no network/GPU.
PLANNER_MODE=llm

# --- LLM router (production) --------------------------------------------------
# Base domain WITHOUT /v1 — the client appends /v1/chat/completions itself.
LLM_BASE_URL=https://litellm.site.avtosushi.net
LLM_MODEL=gemma-4-31b
# 🔒 Router bearer token (value only, WITHOUT the "Bearer " prefix).
LLM_API_KEY=
# response_format=json_object. If LiteLLM/vLLM/model does not support it — set false
# (the engine degrades to parse+repair). Verify with curl from the server.
LLM_FORCE_JSON=true
# Per-request timeout to the model (time.ParseDuration format).
LLM_TIMEOUT=180s

# --- Data source: Report-API (production api.dooglys.com) ---------------------
DGS_CLIENT=api
DGS_REPORT_AUTH=token
DGS_REPORT_BASE=https://api.dooglys.com/api/v1/reports
# 🔒 Shared access-token for all tenants. In THIS project every tenant has its OWN
#    token — leave EMPTY and set it per-tenant (TENANT_<k>_ACCESS_TOKEN below).
DGS_ACCESS_TOKEN=

# --- Logs (JSONL on the ./data volume) ----------------------------------------
# One process for all bots → one file; tenant/user are written on every line.
# Empty → logging disabled.
QUERY_LOG_PATH=/app/data/queries.jsonl
FEEDBACK_LOG_PATH=/app/data/feedback.jsonl

# --- Log directory owner ------------------------------------------------------
# The container runs as THIS uid/gid (docker-compose.yml → user:) so it writes to
# the bind-mounted ./data as your host user — no chown to a foreign uid.
# Find yours: id -u  and  id -g. On most single-user VPS it is 1000/1000.
HOST_UID=1000
HOST_GID=1000

# =============================================================================
# TENANTS (= bots). How to run several bots:
#
#   1) List tenant KEYS comma-separated in TENANTS. A key is an arbitrary label
#      (convenient to use the tenant domain). Each key = a separate bot.
#   2) For each key <k> define a block of TENANT_<k>_* variables.
#
# Tenant identity:
#   TENANTS entry (key) — the ROUTING id: registry, session, log `tenant` (human-readable).
#   TENANT_<k>_ID     — the Dooglys tenant_id UUID. Logged as `tenant_id` and used for the
#                       k8s x-context. Metadata only — does NOT change routing. Empty → not logged.
#   TENANT_<k>_DOMAIN — tenant-domain: Report-API identifies the tenant by it in the external
#                       (token) mode. Unset → = key.
#   TENANT_<k>_ACCESS_TOKEN — OWN per tenant (required; shared DGS_ACCESS_TOKEN unused).
#
# Tenant context (optional, sane defaults):
#   TENANT_<k>_TZ       — IANA timezone for period math ("yesterday", weeks). Default
#                         Europe/Moscow. Invalid value → fail-fast on startup.
#   TENANT_<k>_CURRENCY — display currency. Default RUB.
#   TENANT_<k>_ENABLED  — kill-switch: 0 → the bot replies "under maintenance" and does
#                         not touch data; other tenants unaffected. Default 1 (on).
#
# ALLOWLIST — mixed whitelist, comma-separated: @username AND/OR numeric chat_id.
#   @username — case and '@' don't matter (@Ivan == ivan); handy, but username is mutable.
#   chat_id   — numeric, immutable (more reliable). Find the id via @userinfobot.
#   In APP_ENV=prod at least one entry is required, otherwise fail-fast on startup.
# =============================================================================

# Bots start EXACTLY per the TENANTS list. 5 keys here — drop one if there are 4 bots.
# Comments only on their own line (docker compose env_file may not strip an inline
# '#' after a value → the junk ends up in the variable).
TENANTS=rukagreka,ipkazakova,ambapizza,daynight,wasabi

# --- bot 1: rukagreka ---------------------------------------------------------
# 🔒 @BotFather token:
TENANT_rukagreka_BOT_TOKEN=
# Dooglys tenant_id UUID — logged as tenant_id, used for x-context (empty → not logged):
TENANT_rukagreka_ID=
# tenant-domain for Report-API (empty → = key "rukagreka"):
TENANT_rukagreka_DOMAIN=
TENANT_rukagreka_ALLOWLIST=@owner_ivan, 100200300
# 🔒 tenant's own access-token (each has its own):
TENANT_rukagreka_ACCESS_TOKEN=

# --- bot 2: ipkazakova --------------------------------------------------------
TENANT_ipkazakova_BOT_TOKEN=
TENANT_ipkazakova_ID=
TENANT_ipkazakova_DOMAIN=
# ⚠ a lone '@' below = EMPTY allowlist → in APP_ENV=prod the bot WON'T start. Put a @username or chat_id.
TENANT_ipkazakova_ALLOWLIST=@
TENANT_ipkazakova_ACCESS_TOKEN=

# --- bot 3: ambapizza ---------------------------------------------------------
TENANT_ambapizza_BOT_TOKEN=
TENANT_ambapizza_ID=
TENANT_ambapizza_DOMAIN=
# ⚠ same: fill the allowlist, otherwise fail-fast in prod.
TENANT_ambapizza_ALLOWLIST=@
TENANT_ambapizza_ACCESS_TOKEN=

# --- bot 4: daynight ----------------------------------------------------------
TENANT_daynight_BOT_TOKEN=
TENANT_daynight_ID=
TENANT_daynight_DOMAIN=
TENANT_daynight_ALLOWLIST=400500600
TENANT_daynight_ACCESS_TOKEN=

# --- bot 5: wasabi ------------------------------------------------------------
TENANT_wasabi_BOT_TOKEN=
TENANT_wasabi_ID=
TENANT_wasabi_DOMAIN=
TENANT_wasabi_ALLOWLIST=@owner_petr, 700800900
TENANT_wasabi_ACCESS_TOKEN=

# Add a bot = append a key to TENANTS and a TENANT_<key>_* block — no code changes.
