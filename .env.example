# =============================================================================
# Dooglys AI-bot — шаблон окружения (Telegram-only деплой, N ботов).
# Скопируй в .env рядом с docker-compose.yml и заполни. .env в git НЕ коммитим —
# только этот пример с пустыми секретами.
#
#   cp .env.example .env  &&  <заполнить>  &&  docker compose up -d --build
#
# 🔒 = секрет: живёт ТОЛЬКО в .env на сервере, никогда в git и никогда в образе.
# =============================================================================

# --- Режим приложения ---------------------------------------------------------
# prod → строгие инварианты безопасности: пустой allowlist у тенанта = падение на
#        старте (fail-fast), чтобы бот не оказался открыт всем. dev → послабления.
APP_ENV=prod
# llm → реальная модель через роутер; stub → детерминированные планы без сети/GPU.
PLANNER_MODE=llm

# --- LLM-роутер (боевой) ------------------------------------------------------
# Базовый домен БЕЗ /v1 — клиент сам добавит /v1/chat/completions.
LLM_BASE_URL=https://litellm.site.avtosushi.net
LLM_MODEL=gemma-4-31b
# 🔒 Bearer-токен роутера.
LLM_API_KEY=
# response_format=json_object. Если LiteLLM/vLLM/модель не поддержит — поставь false
# (движок деградирует на parse+repair). Проверить curl'ом с сервера.
LLM_FORCE_JSON=true
# Таймаут одного запроса к модели (формат time.ParseDuration).
LLM_TIMEOUT=180s

# --- Источник данных: Report-API (боевой api.dooglys.com) ---------------------
DGS_CLIENT=api
DGS_REPORT_AUTH=token
DGS_REPORT_BASE=https://api.dooglys.com/api/v1/reports
# 🔒 Общий access-token, ЕСЛИ он один на всех тенантов. Разные токены → оставь
#    пустым и задай пер-тенантно (TENANT_<k>_ACCESS_TOKEN ниже).
DGS_ACCESS_TOKEN=

# --- Логи (JSONL на томе ./data) ----------------------------------------------
# Один процесс на все боты → один файл; tenant/user пишутся в каждой строке.
# Пусто → лог выключен.
QUERY_LOG_PATH=/app/data/queries.jsonl
FEEDBACK_LOG_PATH=/app/data/feedback.jsonl

# =============================================================================
# ТЕНАНТЫ (= боты). Как завести несколько ботов:
#
#   1) Перечисли КЛЮЧИ тенантов через запятую в TENANTS. Ключ — произвольный ярлык
#      (удобно взять = домену тенанта). Каждый ключ = отдельный бот.
#   2) На каждый ключ <k> задай блок переменных TENANT_<k>_*.
#
# Дефолты (пишешь только то, что реально отличается):
#   TENANT_<k>_ID     не задан → = ключ
#   TENANT_<k>_DOMAIN не задан → = ID
#   TENANT_<k>_ACCESS_TOKEN пуст → берётся общий DGS_ACCESS_TOKEN
#
# ALLOWLIST — смешанный whitelist через запятую: @username И/ИЛИ числовой chat_id.
#   @username — регистр и '@' не важны (@Ivan == ivan); удобно, но username изменяем.
#   chat_id   — числовой, неизменяемый (надёжнее). Узнать id: @userinfobot.
#   В APP_ENV=prod хотя бы один элемент обязателен, иначе fail-fast на старте.
# =============================================================================

# Пример: 4 бота. Ключи = домены. Токены разные → заданы пер-тенантно.
TENANTS=rukagreka,tenant2,tenant3,tenant4

# --- бот 1 --------------------------------------------------------------------
# 🔒 токен @BotFather:
TENANT_rukagreka_BOT_TOKEN=
# домен = ключу (rukagreka), поэтому TENANT_rukagreka_DOMAIN можно не задавать.
TENANT_rukagreka_ALLOWLIST=@owner_ivan, 100200300
# 🔒 свой access-token (убери строку, если используешь общий DGS_ACCESS_TOKEN):
TENANT_rukagreka_ACCESS_TOKEN=

# --- бот 2 --------------------------------------------------------------------
TENANT_tenant2_BOT_TOKEN=
TENANT_tenant2_DOMAIN=second-domain
TENANT_tenant2_ALLOWLIST=@owner_maria
TENANT_tenant2_ACCESS_TOKEN=

# --- бот 3 --------------------------------------------------------------------
TENANT_tenant3_BOT_TOKEN=
TENANT_tenant3_DOMAIN=third-domain
TENANT_tenant3_ALLOWLIST=400500600
TENANT_tenant3_ACCESS_TOKEN=

# --- бот 4 --------------------------------------------------------------------
TENANT_tenant4_BOT_TOKEN=
TENANT_tenant4_DOMAIN=fourth-domain
TENANT_tenant4_ALLOWLIST=@owner_petr, 700800900
TENANT_tenant4_ACCESS_TOKEN=

# Добавить 5-го бота = дописать ключ в TENANTS и блок TENANT_<ключ>_* — код не меняется.
