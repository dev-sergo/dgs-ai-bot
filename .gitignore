# === Go ===
# Бинарники и сборки
/bin/
/build/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
dgs-ai-bot

# Тестовое и покрытие
*.test
*.out
coverage.*
profile.*

# Go workspace
go.work
go.work.sum

# === Конфиги и секреты ===
# Локальные конфиги/переменные окружения (коммитим только *.example)
.env
.env.*
!.env.example
config.local.yaml
configs/config.local.yaml
*.local.yaml
secrets/
*.pem
*.key

# === Логи и временное ===
*.log
logs/
tmp/
.tmp/

# === Артефакты бенчмарков/eval ===
# Корпуса (test/eval/*.jsonl) и сами прогоны (bench/runs/) коммитим.
# Игнорим: результаты в старом формате (до контракта) и шум в корне.
test/eval/results/
bench-results/
eval-results*.txt
quality-run*.txt
/pipeval*.txt
/batch-*.log
/server-*.log
/bot-*.log
/n[0-9]-*.log
/n[0-9][0-9]-*.log

# === Сырой HTML из харвестера (живые данные, не коммитим) ===
docs/contracts/fixtures/raw/

# === IDE / редакторы ===
.idea/
.vscode/
*.swp
*.swo
*~

# === ОС ===
.DS_Store
Thumbs.db

# === Python (инструменты сбора фикстур) ===
__pycache__/
*.pyc
.venv/
venv/

# === Docker ===
# (compose-файлы коммитим; volume-данные — нет)
docker-data/
# Датасет вопрос→план→ответ (живые запросы пользователей — не коммитим)
/data/*
!/data/.gitkeep

# === Frontend (web/) ===
node_modules/
web/dist/

# === Ручные probe-прогоны (test/manual/) ===
# Скрипты-харнессы коммитим, выводы прогонов (логи/JSON/скачанные xlsx) — нет.
test/manual/*.log
test/manual/*.json
test/manual/xlsx/

# local secret probe (live cookie)
probe_report.sh

# spike / ad-hoc experiments
spike_results-*.jsonl
/scripts/spike_*.py
/scripts/spike_*.jsonl

# === Курируемая история бенчмарков (bench/) ===
# Прогоны качества — это документация прогресса, их коммитим (исключение из *.log выше).
!bench/runs/*.log
